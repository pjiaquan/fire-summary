{
  "manifest_version": 3,
  "name": "Fire Summary",
  "version": "0.1.0",
  "description": "Extract the current page and summarize it with the bundled Rust/Wasm module.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Fire Summary",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+X"
      }
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://generativelanguage.googleapis.com;"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fire-summary@example.com"
    }
  }
}
